# ===========================================================
# Polaris Desk — 環境設定範本
# 用法：cp .env.example .env  然後填入你的值
# ⚠️ .env 不可 commit 進 git（已列入 .gitignore）
# ===========================================================

# --- 向量庫後端：預設 BigQuery（共用 canonical）；pgvector 為離線 fallback ---
#     這一個變數就是「雲端 ↔ 本地」的開關。完整說明見 docs/開發環境_BigQuery.md
VECTOR_BACKEND=bigquery            # bigquery（預設）| pgvector（離線 / Demo fallback）

# --- 雲端 BigQuery（預設後端）---
#     認證走 ADC：先跑 `gcloud auth application-default login`（金鑰勿寫死、勿 commit）
GCP_PROJECT=polaris-desk-team
BQ_DATASET=polaris_core            # 共用唯讀 canonical（全員 READER）
DEV_DATASET=polaris_dev_<name>     # 你的個人 scratch（只你可寫）；見 SOP §5，把 <name> 換成你的英文名
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # 雲端部署用 SA 才需要

# --- 本地 pgvector（離線 / Demo fallback；VECTOR_BACKEND=pgvector 時才需要）---
#     先 `make db-up` 起 Docker Postgres，再把上面切成 pgvector
DATABASE_URL=postgresql://polaris:polaris@localhost:5432/polaris

# --- LLM / 檢索 API 金鑰 ---
GEMINI_API_KEY=                    # 必填（主力模型 Gemini 3.0 Pro/Flash）
COHERE_API_KEY=                    # Rerank 重排
TAVILY_API_KEY=                    # Deep Research 網路搜尋

# --- Eval 三方投票（R5 用）---
ANTHROPIC_API_KEY=                 # Claude Judge
OPENAI_API_KEY=                    # GPT Judge

# --- 模型名稱（google-genai SDK 也會自動讀 GEMINI_API_KEY / GOOGLE_API_KEY）---
GEMINI_MODEL_PRO=gemini-3-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-2          # 最新多模態嵌入（文字/圖/影片/音訊/PDF，token 上限 8192）
EMBEDDING_DIM=768                           # gemini-embedding-2 支援 128–3072，建議 768/1536/3072

# --- 應用設定 ---
APP_ENV=local                      # local | cloud
LOG_LEVEL=INFO
TOP_K=8                            # 檢索回傳筆數

# --- API CORS（R7 前端跨域）---
#     thin API（polaris/api.py）允許的前端來源；逗號分隔。雲端換成 R7 的 Vercel 網域。
POLARIS_CORS_ORIGINS=http://localhost:3000,http://localhost:8501   # Next.js / Chainlit dev

# --- 使用者登入（R7-1：Google OAuth + Firestore 活動紀錄）---
#     後端只需 client_id 驗 Google id_token 的 aud；client secret 留前端（NextAuth）。
#     留空 = 全程匿名（token-free CI / 斷網降級照常）。Firestore 走 ADC（runtime SA），免金鑰。
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
