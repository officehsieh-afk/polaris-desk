# ⚠️ 金鑰 / 本地設定 — 永不 commit
.env
.env.*
!.env.example
*.key
*-service-account.json
credentials.json
core_access.json
*_access.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.eggs/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
# uv 會在 uv run / uv sync 時自動生成；本專案用 uv pip install（不吃 lock），
# 故不追蹤以免每人 git status 都跳 ?? uv.lock。要做依賴鎖定再改走 uv sync。
uv.lock

# Node / 前端
node_modules/
.next/
dist/
build/
frontend/.next/dev/logs/

# 資料 / 暫存（法說會 PDF、向量等不進 git）
/data/
*.pdf
*.parquet
*.duckdb
*.sqlite

# OS / IDE
.DS_Store
.idea/
.vscode/

# Google Drive / macOS 同步衝突副本（如 "foo 2.py"）— 不 commit、不讓 pytest 收集
* [0-9].py
* [0-9].md

# TypeScript build cache（自動產生）
*.tsbuildinfo

# Coding agent 本地設定（可能含憑證）— 不 commit
# 註：.claude/skills/ 的 spec-kit 指令「要」保留共用，故不整個忽略 .claude/
.claude/settings.local.json
.claude/*.local.json
.claude/worktrees/
